{
  "name": "@pi-claude-code-agent/teams-backend",
  "version": "0.4.1",
  "type": "module",
  "description": "Persistent teammate backend on top of Claude runtime intercom bridge",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "claude-team-demo": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx ./test/**/*.test.ts",
    "demo": "tsx src/cli.ts"
  },
  "dependencies": {
    "@pi-claude-code-agent/intercom-bridge": "file:../intercom-bridge",
    "@pi-claude-code-agent/runtime": "file:../runtime"
  },
  "devDependencies": {
    "tsx": "^4.20.6"
  }
}
