{
  "name": "@pi-claude-code-agent/runtime",
  "version": "0.6.0",
  "type": "module",
  "description": "Reusable Claude Code runtime package",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "claude-runtime-smoke": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx ./test/**/*.test.ts",
    "smoke": "tsx src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126"
  },
  "devDependencies": {
    "tsx": "^4.20.6"
  }
}
