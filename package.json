{
  "name": "pi-claude-code-agent",
  "private": true,
  "version": "0.1.0",
  "description": "Planning and implementation repo for Claude Code integration with pi, pi-intercom, pi-subagents, and pi-teams",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "claude-code",
    "agent-runtime"
  ],
  "workspaces": [
    "packages/*"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "smoke": "npm run smoke --workspace @pi-claude-code-agent/runtime",
    "demo:intercom": "npm run demo --workspace @pi-claude-code-agent/intercom-bridge",
    "demo:subagent": "npm run demo --workspace @pi-claude-code-agent/subagents-backend",
    "demo:teams": "npm run demo --workspace @pi-claude-code-agent/teams-backend",
    "plan:check": "echo 'Runtime + intercom bridge + subagents backend + teams backend implemented as local MVP packages'"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
